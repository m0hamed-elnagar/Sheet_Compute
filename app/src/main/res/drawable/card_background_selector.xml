<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state: Distinct background and bright border -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#2D333B" /> <!-- Lighter than dark_card_header -->
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/accent" />
        </shape>
    </item>
    
    <!-- Default state: Standard dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/dark_card_header" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/dark_border" />
        </shape>
    </item>
</selector>